    {
      "title": "EGA (European Genome-phenome Archive)",
      "description": "European Genome-phenome Archive (EGA) is a service for sharing personally identifiable [genetic](/topics/gdpr-ethical-review-glossary/#genetic-data) and phenotypic data resulting from biomedical research projects. The repository is hosted by the European Bioinformatics Institute (EMBL-EBI) and the Centre for Genomic Regulation (CRG). Any data submitted to the repository is subject to controlled access, which means that access to the data only will be granted after a formal application procedure.",
      "url": "https://ega-archive.org",
      "submission_guidelines": "https://ega-archive.org/submission/metadata/submission/sequencing-phenotype/submitter-portal/",
      "info_type": ["Repository"],
      "category": "Genomics",
      "keywords": [],
      "SLL_service_area": ["Genomics"],
      "study_type": ["Genomics", "Clinical Genomics", "Precision Medicine"],
      "data_type": ["Raw Reads", "Genotypes","Controlled Access Data"]
    },
    {
      "title": "FEGA (Federated European Genome-phenome Archive) Sweden",
      "description": "FEGA Sweden is a repository for storing and sharing personally identifiable [genetic](/topics/gdpr-ethical-review-glossary/#genetic-data) and phenotypic data in Sweden in a way that meets the requirements of the [General Data Protection Regulation (GDPR)](/topics/gdpr-ethical-review-glossary/#gdpr-general-data-protection-regulation). It is part of the [Federated European Genome-phenome Archive](https://ega-archive.org/about/projects-and-funders/federated-ega/), which is a network consisting of several national nodes and the European Genome-phenome Archive (EGA). Researchers can create a submission request by filling in a form on the website.",
      "url": "https://fega.nbis.se",
      "submission_guidelines": "https://fega.nbis.se/submission/",
      "info_type": ["Repository"],
      "category": "Genomics",
